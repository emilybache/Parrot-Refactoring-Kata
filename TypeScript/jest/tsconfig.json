{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["esnext"],
    "module": "node16",
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "./build/",
    "noEmitOnError": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": false,
    "typeRoots": ["./node_modules/@types"],
    "types": ["jest"]
  },
  "include": [
    "./src/**.ts",
    "./tests/*.spec.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
